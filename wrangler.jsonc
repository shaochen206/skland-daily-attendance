{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-05-17",
  "name": "skland-daily-attendance",
  "compatibility_flags": ["nodejs_als"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "KV","id": "e2dc0cbdabec4c06a4b9edaeb87673db"
    }
  ],
  "triggers": {
    "crons": ["30 */2 * * *"]
  }
}
